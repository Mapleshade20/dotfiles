{% if yadm.os == "Linux" %}
{% if env.RESOLUTION == "4k" %}
font_size 12.0
window_padding_width 10
{% else %}
# 1080p, undefined yet
{% endif %}
{% endif %}
{% if yadm.os == "Darwin" %}
font_size   15.0
window_padding_width  3
macos_option_as_alt   yes
{% endif %}

# Common keybinds
map ctrl+shift+enter launch --cwd=current

# Common settings
background_opacity    0.9
background_blur       40
scrollback_lines 3000
shell_integration enabled
strip_trailing_spaces smart
enable_audio_bell no

cursor_trail                  3
cursor_trail_start_threshold  -1
cursor_shape block
cursor_shape_unfocused        hollow

# Common theme
include common-theme.conf

# font_family      JetBrains Mono
# bold_font        auto
# italic_font      auto
# bold_italic_font auto

font_family        Maple Mono Light
bold_font          Maple Mono Bold
italic_font        Maple Mono Light Italic
bold_italic_font   Maple Mono SemiBold Italic
# font_features      MapleMono-ExtraLightItalic +cv35
modify_font cell_width 97%
modify_font cell_height 103%

#: To get the PostScript name, use `kitty +list-fonts --psnames`
#: The part in brackets is the PostScript name.
